[Unit]
Description=PersonalWebsite FastAPI service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/home/nshep6998/PersonalWebsite/backend
Environment=PORT=8000
Environment=APP_DOMAIN=https://nathanieljshepherd.com
Environment=ALLOWED_ORIGINS=https://nathanieljshepherd.com,https://www.nathanieljshepherd.com
ExecStart=/home/nshep6998/PersonalWebsite/backend/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target